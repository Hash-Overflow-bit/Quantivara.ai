rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /market_data/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /market_movers/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /market_sectors/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /charts/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /expected_movers/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /market_watch/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /volume_spikes/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /predictions/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /foreign_flow/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /market_briefs/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /news/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /announcements/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /signal_log/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /prediction_history/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /{document=**} {
      // By default, only authenticated users can read and write to the database.
      allow read, write: if request.auth != null;
    }
  }
}
